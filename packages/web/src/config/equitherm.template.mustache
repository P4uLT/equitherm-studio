# Generated by Equitherm Calculator
# {{date}}
#
# ESPHome equitherm climate component configuration
# Docs: https://esphome.io/components/climate/equitherm.html

climate:
  - platform: equitherm
    id: heating_controller
    name: "Equitherm Heating"

    # Required sensors
    outdoor_sensor: outdoor_sensor
    indoor_sensor: indoor_sensor
    default_target_temperature: {{t}}°C

    # Fallback configuration
    fallback_outdoor_temp: 0.0°C
    sensor_stale_timeout: 10min

    # Output (choose ONE)
    heat_output: heat_output
    # flow_setpoint: flow_setpoint
{{#controlParams}}

    # Heating curve + PID parameters
    control_parameters:
      heat_curve_coefficient: {{hc}}
      heat_curve_exponent: {{n}}{{#shift}}
      heat_curve_shift: {{shift}}{{/shift}}{{#kp}}
      kp: {{kp}}{{/kp}}{{#ki}}
      ki: {{ki}}{{/ki}}{{#kd}}
      kd: {{kd}}{{/kd}}
{{/controlParams}}
{{#outputParams}}
    # Output behavior
    output_parameters:
      min_flow_temp: {{minFlow}}°C
      max_flow_temp: {{maxFlow}}°C{{#deadbandParams}}
    deadband_parameters:
      threshold_low: {{thresholdLow}}
      threshold_high: {{thresholdHigh}}{{#kpMultiplier}}
      kp_multiplier: {{kpMultiplier}}{{/kpMultiplier}}{{#kiMultiplier}}
      ki_multiplier: {{kiMultiplier}}{{/kiMultiplier}}{{#kdMultiplier}}
      kd_multiplier: {{kdMultiplier}}{{/kdMultiplier}}
{{/deadbandParams}}
{{/outputParams}}
{{#includeSensors}}

# Diagnostic sensors
sensor:
  - platform: equitherm
    climate_id: heating_controller
    type: curve_output_raw
    name: "Curve Output Raw"
  - platform: equitherm
    climate_id: heating_controller
    type: base_curve_output
    name: "Base Curve Output"
  - platform: equitherm
    climate_id: heating_controller
    type: final_flow_setpoint
    name: "Final Flow Setpoint"
  - platform: equitherm
    climate_id: heating_controller
    type: last_written_setpoint
    name: "Last Written Setpoint"{{#pid}}
  - platform: equitherm
    climate_id: heating_controller
    type: pid_correction
    name: "PID Correction"
  - platform: equitherm
    climate_id: heating_controller
    type: proportional_term
    name: "PID P-Term"
  - platform: equitherm
    climate_id: heating_controller
    type: integral_term
    name: "PID I-Term"
  - platform: equitherm
    climate_id: heating_controller
    type: derivative_term
    name: "PID D-Term"{{/pid}}
  - platform: equitherm
    climate_id: heating_controller
    type: fallback_duration
    name: "Fallback Duration"

# Diagnostic binary sensors
binary_sensor:
  - platform: equitherm
    climate_id: heating_controller
    outdoor_fallback_active:
      name: "Outdoor Fallback"
    indoor_fallback_active:
      name: "Indoor Fallback"

# Diagnostic text sensor
text_sensor:
  - platform: equitherm
    climate_id: heating_controller
    control_mode:
      name: "Control Mode"
{{/includeSensors}}
{{#includeNumbers}}

# Runtime tuning
number:
  - platform: equitherm
    climate_id: heating_controller
    heat_curve_coefficient:
      name: "HC Coefficient"
  - platform: equitherm
    climate_id: heating_controller
    heat_curve_exponent:
      name: "HC Exponent"{{#hasShift}}
  - platform: equitherm
    climate_id: heating_controller
    heat_curve_shift:
      name: "HC Shift"{{/hasShift}}{{#hasKp}}
  - platform: equitherm
    climate_id: heating_controller
    pid_proportional_gain:
      name: "PID Kp"{{/hasKp}}{{#hasKi}}
  - platform: equitherm
    climate_id: heating_controller
    pid_integral_gain:
      name: "PID Ki"{{/hasKi}}{{#hasKd}}
  - platform: equitherm
    climate_id: heating_controller
    pid_derivative_gain:
      name: "PID Kd"{{/hasKd}}
{{/includeNumbers}}
