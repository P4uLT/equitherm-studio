# Generated by Equitherm Calculator
# {{date}}
#
# ESPHome equitherm climate component configuration
# Docs: https://esphome.io/components/climate/equitherm.html

climate:
  - platform: equitherm
    id: heating_controller
    name: "Equitherm Heating"

    # Required sensors
    outdoor_sensor: outdoor_sensor
    indoor_sensor: indoor_sensor
    default_target_temperature: {{t}}°C

    # Output (choose ONE)
    heat_output: heat_output
    # flow_setpoint: flow_setpoint
{{#controlParams}}

    # Heating curve + PID parameters
    control_parameters:
      heat_curve_coefficient: {{hc}}
      heat_curve_exponent: {{n}}{{#shift}}
      heat_curve_shift: {{shift}}{{/shift}}{{#kp}}
      kp: {{kp}}{{/kp}}{{#ki}}
      ki: {{ki}}{{/ki}}{{#kd}}
      kd: {{kd}}{{/kd}}
{{/controlParams}}
{{#outputParams}}
    # Output behavior
    output_parameters:
      min_flow_temp: {{minFlow}}°C
      max_flow_temp: {{maxFlow}}°C
{{/outputParams}}{{#deadbandParams}}
    deadband_parameters:
      threshold_low: {{thresholdLow}}°C
      threshold_high: {{thresholdHigh}}°C{{#kpMultiplier}}
      kp_multiplier: {{kpMultiplier}}{{/kpMultiplier}}{{#kiMultiplier}}
      ki_multiplier: {{kiMultiplier}}{{/kiMultiplier}}{{#kdMultiplier}}
      kd_multiplier: {{kdMultiplier}}{{/kdMultiplier}}
{{/deadbandParams}}
{{#includeSensors}}

# Diagnostic sensors
sensor:
  - platform: equitherm
    climate_id: heating_controller
    type: HEATING_CURVE_OUTPUT
    name: "Heating Curve Output"
  - platform: equitherm
    climate_id: heating_controller
    type: PID_ADJUSTED_OUTPUT
    name: "PID Adjusted Output"
  - platform: equitherm
    climate_id: heating_controller
    type: FLOW_SETPOINT
    name: "Flow Setpoint"
  - platform: equitherm
    climate_id: heating_controller
    type: ACTIVE_SETPOINT
    name: "Active Setpoint"{{#pid}}
  - platform: equitherm
    climate_id: heating_controller
    type: PID_CORRECTION
    name: "PID Correction"
  - platform: equitherm
    climate_id: heating_controller
    type: PID_PROPORTIONAL
    name: "PID P-Term"
  - platform: equitherm
    climate_id: heating_controller
    type: PID_INTEGRAL
    name: "PID I-Term"
  - platform: equitherm
    climate_id: heating_controller
    type: PID_DERIVATIVE
    name: "PID D-Term"{{/pid}}
  - platform: equitherm
    climate_id: heating_controller
    type: FALLBACK_DURATION
    name: "Fallback Duration"

# Diagnostic binary sensors
binary_sensor:
  - platform: equitherm
    climate_id: heating_controller
    outdoor_fallback_active:
      name: "Outdoor Fallback"
    indoor_fallback_active:
      name: "Indoor Fallback"

# Diagnostic text sensor
text_sensor:
  - platform: equitherm
    climate_id: heating_controller
    control_mode:
      name: "Control Mode"
{{/includeSensors}}
{{#includeNumbers}}

# Runtime tuning
number:
  - platform: equitherm
    climate_id: heating_controller
    heat_curve_coefficient:
      name: "HC Coefficient"
  - platform: equitherm
    climate_id: heating_controller
    heat_curve_exponent:
      name: "HC Exponent"{{#hasShift}}
  - platform: equitherm
    climate_id: heating_controller
    heat_curve_shift:
      name: "HC Shift"{{/hasShift}}{{#hasKp}}
  - platform: equitherm
    climate_id: heating_controller
    pid_proportional_gain:
      name: "PID Kp"{{/hasKp}}{{#hasKi}}
  - platform: equitherm
    climate_id: heating_controller
    pid_integral_gain:
      name: "PID Ki"{{/hasKi}}{{#hasKd}}
  - platform: equitherm
    climate_id: heating_controller
    pid_derivative_gain:
      name: "PID Kd"{{/hasKd}}
{{/includeNumbers}}
