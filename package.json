{
  "name": "equitherm-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Companion tools for the ESPHome equitherm climate component",
  "author": "P4uLT",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/P4uLT/equitherm-studio.git"
  },
  "homepage": "https://p4ult.github.io/equitherm-studio/",
  "bugs": {
    "url": "https://github.com/P4uLT/equitherm-studio/issues"
  },
  "keywords": [
    "esphome",
    "equitherm",
    "heating",
    "climate",
    "pid",
    "hvac"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:core": "pnpm --filter @equitherm-studio/core dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "tag": "node scripts/tag-release.mjs",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.12.2"
}
